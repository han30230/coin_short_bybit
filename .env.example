# Bybit (필수)
BYBIT_API_KEY_SH=your_api_key
BYBIT_SECRET_SH=your_secret

BYBIT_ENV=mainnet
BYBIT_RECV_WINDOW=8000

LEVERAGE=5
HTTP_MAX_RETRIES=5
FORCE_HEDGE=true

# 계정별 state/logs 분리 권장 (run_bybit_account.py 또는 Bybit_SH_1.py 기본: state/sh/, logs/sh/)
POSITION_STATE_FILE=state/sh/position_state.json
SUPERTREND_WATCH_STATE_FILE=state/sh/supertrend_watch.json
TRADE_JOURNAL_FILE=logs/sh/trade_journal.csv

MAX_CONCURRENT_POSITIONS=50
EXIT_CLOSE_MAX_RETRIES=5

FILTER_UPBIT_LISTED=false
FILTER_SPOT_COEXIST=false
FILTER_FUTURES_LISTING_AGE=false
MIN_FUTURES_LISTING_AGE_DAYS=365

# 급등 스캔 (+25% 이상 후보, ST 감시 최대 30종 — 해제 없음)
GAINER_THRESHOLD_PCT=25
QUALIFIED_WATCH_TOP_N=30
MIN_VOLUME_USDT=100000

# 시가총액 (기본 OFF — CMC 키 있어도 USE_MCAP_FILTER=true 일 때만 적용)
CMC_API_KEY=
USE_MCAP_FILTER=false
MCAP_FAIL_OPEN=true
MIN_MARKET_CAP_USD=1000000
MCAP_CACHE_TTL_SEC=900
FILTER_MCAP_FDV=false

# 1차 진입 5m RSI/MA 필터 (기본 OFF)
USE_ENTRY_INDICATOR_FILTER=false

# 재진입 (기본 OFF — ST 숏 1회만)
USE_REENTRY=false
USE_REENTRY_INDICATOR_FILTER=true
INDICATOR_INTERVAL=5m
INDICATOR_KLINE_LIMIT=60
INDICATOR_CACHE_TTL_SEC=60
REENTRY_RSI_THRESHOLD=80
REENTRY_MA20_GAP_PCT=1.0
REENTRY_RECENT_OVER_BARS=5

# SuperTrend: 4h 진입(숏) / 청산(롱), 고정 TP 기본 OFF
USE_SUPERTREND_ENTRY=true
USE_SUPERTREND_EXIT=true
USE_FIXED_TP=false
SUPERTREND_INTERVAL=4h
SUPERTREND_ATR_PERIOD=4
SUPERTREND_FACTOR=7
SUPERTREND_SOURCE=hl2
SUPERTREND_KLINE_LIMIT=100

COINGECKO_API_BASE=https://api.coingecko.com/api/v3
