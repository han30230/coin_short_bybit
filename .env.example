# Bybit (필수)
BYBIT_API_KEY_SH=your_api_key
BYBIT_SECRET_SH=your_secret
# 또는 공용 이름
# BYBIT_API_KEY=
# BYBIT_SECRET=

BYBIT_ENV=mainnet
BYBIT_RECV_WINDOW=8000

LEVERAGE=5
HTTP_MAX_RETRIES=5
FORCE_HEDGE=true

POSITION_STATE_FILE=position_state.json
TRADE_JOURNAL_FILE=logs/trade_journal.csv

FILTER_UPBIT_LISTED=true
MIN_FUTURES_LISTING_AGE_DAYS=365
MIN_FUNDING_RATE=-0.005

USE_ENTRY_INDICATOR_FILTER=true
USE_REENTRY_INDICATOR_FILTER=true
INDICATOR_INTERVAL=5m
INDICATOR_KLINE_LIMIT=60
INDICATOR_CACHE_TTL_SEC=60

ENTRY_RSI_THRESHOLD=78
ENTRY_MA20_GAP_PCT=1.0
REENTRY_RSI_THRESHOLD=80
REENTRY_MA20_GAP_PCT=1.0
REENTRY_RECENT_OVER_BARS=5

# SuperTrend 1차 진입 (TV: 4h / ATR 4 / Factor 7 / hl2, 하락추세 포함)
USE_SUPERTREND_ENTRY=true
SUPERTREND_INTERVAL=4h
SUPERTREND_ATR_PERIOD=4
SUPERTREND_FACTOR=7
SUPERTREND_SOURCE=hl2
SUPERTREND_KLINE_LIMIT=100
SUPERTREND_WATCH_STATE_FILE=supertrend_watch.json

# 시가총액 필터 (선택, CoinMarketCap)
CMC_API_KEY=
MIN_MARKET_CAP_USD=100000000
MCAP_CACHE_TTL_SEC=900

FILTER_MCAP_FDV=true
MIN_MCAP_FDV_RATIO=0.4
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
